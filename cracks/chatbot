local function processPlayerMessage(messageContent)
    local plr, childPlayer, targetPlayer = pairs(game.Players:GetChildren())

    while true do
        local displayName

        targetPlayer, displayName = plr(childPlayer, targetPlayer)

        if targetPlayer == nil then
            break
        end

        local messageLength = #messageContent

        if displayName.Name:sub(1, messageLength) == messageContent then
            return displayName.Name, displayName.DisplayName
        end
    end

    local p, playerInstance, currentPlayer = pairs(game.Players:GetChildren())

    while true do
        local char

        currentPlayer, char = p(playerInstance, currentPlayer)

        if currentPlayer == nil then
            break
        end

        local contentLength = #messageContent

        if char.DisplayName:sub(1, contentLength) == messageContent then
            return char.Name, char.DisplayName
        end
    end

    return nil, nil
end
local function handlePlayerChat(chatMessage)
    local playerObj, plrInstance, playerEntry = pairs(game.Players:GetChildren())

    while true do
        local username

        playerEntry, username = playerObj(plrInstance, playerEntry)

        if playerEntry == nil then
            break
        end

        local prefixLength = #chatMessage
        local usernamePrefix = username.Name:sub(1, prefixLength)

        if string.lower(usernamePrefix) == chatMessage then
            return username
        end
    end

    local playerChar, characterModel, charInstance = pairs(game.Players:GetChildren())

    while true do
        local fullDisplayName

        charInstance, fullDisplayName = playerChar(characterModel, charInstance)

        if charInstance == nil then
            break
        end

        local displayNameLength = #chatMessage
        local displayNamePrefix = fullDisplayName.DisplayName:sub(1, displayNameLength)

        if string.lower(displayNamePrefix) == chatMessage then
            return fullDisplayName
        end
    end

    return nil, nil
end
