local function customAis(aiDataString)
    local aiEntry, aiName, aiPrompt = string.gmatch(aiDataString, '([^,]+)')

    while true do
        aiPrompt = aiEntry(aiName, aiPrompt)

        if aiPrompt == nil then
            break
        end

        local aiModelName, aiPromptValue = string.match(aiPrompt, '([^:]+):([^:]+)')

        if aiModelName and aiPromptValue then
            _G.CHATBOTHUB_CUSTOMAIS[aiModelName] = aiPromptValue
        end
    end
end

function encodeAIs()
    local aiKey, aiTable, aiConfig = pairs(_G.CHATBOTHUB_CUSTOMAIS)
    local savedAis = {}

    while true do
        local fileReadSuccess

        aiConfig, fileReadSuccess = aiKey(aiTable, aiConfig)

        if aiConfig == nil then
            break
        end

        table.insert(savedAis, aiConfig .. ':' .. fileReadSuccess)
    end

    return table.concat(savedAis, ',')
end

