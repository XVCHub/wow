local pathfindingService = game:GetService('PathfindingService')

local function generateAiResponse(prompt2)
    local playerHumanoid = localPlayer.Character.Humanoid
    local playerRootPart2 = localPlayer.Character.HumanoidRootPart
    local targetPosition = prompt2.Character.HumanoidRootPart.Position
    local path = pathfindingService:CreatePath()

    local function findPath()
        path = pathfindingService:CreatePath()

        path:ComputeAsync(playerRootPart2.Position, targetPosition)

        return path:GetWaypoints()
    end

    local waypoints = findPath()
    local waypoint, waypointIndex, waypointPosition = pairs(waypoints)
    local destination = targetPosition
    local maxDistance = 3

    while true do
        local moveToWaypoint, moveSuccess = waypoint(waypointIndex, waypointPosition)

        if moveToWaypoint == nil then
            break
        end

        waypointPosition = moveToWaypoint

        playerHumanoid:MoveTo(moveSuccess.Position)

        if moveSuccess.Action == Enum.PathWaypointAction.Jump then
            playerHumanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        end

        local currentPath = nil

        currentPath = playerHumanoid.MoveToFinished:Connect(function(player9)
            if player9 then
                if maxDistance < (newDestination - destination).magnitude then
                    print('Target player moved, recalculating path...')

                    destination = newDestination
                    waypoints = findPath()
                    moveToWaypoint = 1
                end

                currentPath:Disconnect()
            else
                warn('Movement interrupted!')
                currentPath:Disconnect()
            end
        end)
    end
end

