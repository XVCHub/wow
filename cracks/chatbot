local function blacklistedContent(inputText)
    local lowerInput = string.lower(inputText)

    if lowerInput == 'stop' then
        validateAndSend()

        return
    elseif lowerInput == 'jump' then
        orionLib2()

        return
    elseif lowerInput == 'spin' then
        blacklistedPlayers()

        return
    elseif lowerInput ~= 'null' then
        local targetPlayerName = string.match(lowerInput, '^follow%s+(.+)')

        if targetPlayerName then
            displayNameToFullName(targetPlayerName)
        end
    end
