local ProximityPromptModule = {}
local ProximityPromptService = game:GetService("ProximityPromptService")
local connections = {}
local originalDurations = {}
local isEnabled = false

function ProximityPromptModule:Enable()
	if isEnabled then return end
	isEnabled = true

	connections.promptShown = ProximityPromptService.PromptShown:Connect(function(prompt)
		if originalDurations[prompt] then return end
		originalDurations[prompt] = prompt.HoldDuration
		prompt.HoldDuration = 0
	end)

	connections.promptHidden = ProximityPromptService.PromptHidden:Connect(function(prompt)
		if not originalDurations[prompt] then return end
		prompt.HoldDuration = originalDurations[prompt]
		originalDurations[prompt] = nil
	end)
end

function ProximityPromptModule:Disable()
	if not isEnabled then return end
	isEnabled = false

	if connections.promptShown then
		connections.promptShown:Disconnect()
		connections.promptShown = nil
	end

	if connections.promptHidden then
		connections.promptHidden:Disconnect()
		connections.promptHidden = nil
	end

	for prompt, duration in pairs(originalDurations) do
		if prompt and prompt.Parent then
			prompt.HoldDuration = duration
		end
	end

	table.clear(originalDurations)
end

return ProximityPromptModule
